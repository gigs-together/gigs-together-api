# (optional) Port for the NestJS server. Default = 3000
PORT=

# Telegram
BOT_ADMINS={"username1":123,"username2":124}
ADMIN_CACHE_TTL_MS=
ADMIN_REVALIDATE_SECRET=
BOT_TOKEN=
# Max age in seconds for WebApp initData `auth_date` (replay window). Default 86400 (24h).
TELEGRAM_INIT_DATA_MAX_AGE_SEC=
# Access JWT (short-lived) and refresh JWT (long-lived). Required in all environments.
JWT_SECRET=
# Refresh JWT secret (must differ from JWT_SECRET in production).
JWT_REFRESH_SECRET=
# Access JWT TTL in seconds (JWT `exp` and access cookie `maxAge`). Default 3600 (1 h).
JWT_ACCESS_EXPIRES_IN_SEC=
# Refresh JWT TTL in seconds (refresh cookie `maxAge`). Default 2_592_000 (30 d).
JWT_REFRESH_EXPIRES_IN_SEC=

# HttpOnly access + refresh JWT cookies (optional; defaults in AuthCookiesService).
# *_TOKEN_COOKIE_NAME — default gt_access/gt_refresh
# *_TOKEN_COOKIE_SECURE — true | false | unset (unset => Secure only when NODE_ENV=prod)
# *_TOKEN_COOKIE_SAMESITE — lax | strict | none (none needs Secure; use for cross-site cookie)
# *_TOKEN_COOKIE_DOMAIN — e.g. .example.com for subdomains (omit for host-only cookie)
ACCESS_TOKEN_COOKIE_NAME=
ACCESS_TOKEN_COOKIE_SECURE=
ACCESS_TOKEN_COOKIE_SAMESITE=
ACCESS_TOKEN_COOKIE_DOMAIN=
REFRESH_TOKEN_COOKIE_NAME=
REFRESH_TOKEN_COOKIE_SECURE=
REFRESH_TOKEN_COOKIE_SAMESITE=
REFRESH_TOKEN_COOKIE_DOMAIN=

BOT_SECRET=
MAIN_CHANNEL_ID=
MODERATION_CHANNEL_ID=
DIRECT_MESSAGES_URL=
EDIT_GIG_URL=

# Mongo DB
MONGO_URI=mongodb://<HOST>:<PORT>/<DBNAME>
MONGO_DB=<DBNAME>
MONGO_PORT=<PORT>

# Google
CALENDAR_ID=
GOOGLE_AUTH_JSON=# "google-auth.json" base64 encoded or raw

# S3-compatible storage (Cloudflare R2 recommended)
# Required for public bucket mode (R2):
# - S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# - S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY from R2 API tokens
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional (defaults to "gigs")
S3_POSTERS_PREFIX=
# REQUIRED: public bucket base URL (R2 public bucket URL / CDN / custom domain)
S3_PUBLIC_BASE_URL=

CORS_ORIGINS=

EXTERNAL_POSTER_URL_FALLBACK_ENABLED=

# Optional: used when creating a gig without poster.
# Should be a direct, publicly accessible image URL.
DEFAULT_GIG_POSTER_URL=

AI_URL=
AI_API_KEY=
AI_MODEL=
AI_LOOKUP_DEBUG=
AI_LOOKUP_PERPLEXITY_PLAIN=

APP_BASE_URL=

# Optional: used to trigger Next.js on-demand revalidation after publishing a gig.
# - APP_BASE_URL should point to the frontend base URL (e.g. https://gigs.example.com)
# - FEED_REVALIDATE_SECRET must match frontend FEED_REVALIDATE_SECRET
FEED_REVALIDATE_SECRET=